{
  "expo": {
    "name": "eHosp",
    "slug": "app-ehosp",
    "scheme": "ehosp-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fr.ehosp.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "fr.ehosp.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Autorisez eHosp à utiliser Face ID pour sécuriser vos données de santé."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "eHosp a besoin de la caméra pour analyser vos ordonnances et rapports médicaux avec le Dr. IA.",
          "microphonePermission": "eHosp a besoin du microphone pour que vous puissiez parler vocalement au Dr. IA."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "eHosp a besoin d'accéder à vos photos pour analyser vos résultats médicaux."
        }
      ],
      [
        "expo-apple-authentication"
      ],
      "expo-notifications",
      "expo-location",
      "expo-asset"
    ]
  }
}
